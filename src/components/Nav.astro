---
import { Image } from "astro:assets";
import data from "../data/site.json";
import DarkModeToggle from "./DarkModeToggle.astro";
import Logo from "../assets/logo.png";
---

<nav class="glass fixed w-full z-9999 top-0 inset-s-0">
  <div
    class="max-w-7xl flex flex-wrap items-center justify-between mx-auto p-4 md:px-6 animate-in fade-in slide-in-from-top-4 duration-700"
  >
    <a href="/" class="flex justify-between">
      <Image
        src={Logo}
        width={40}
        height={40}
        format="avif"
        quality={60}
        alt="Sublime UX Logo"
      />
      <span
        class="self-center text-2xl font-semibold whitespace-nowrap text-primaryDrk dark:text-white"
        >{data.siteName}</span
      >
    </a>
    <button
      data-collapse-toggle="targetEl"
      id="triggerEl"
      type="button"
      class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-700 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
      aria-controls="targetEl"
      aria-expanded="false"
    >
      <span class="sr-only">Open main menu</span>
      <svg
        class="w-5 h-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 17 14"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="targetEl">
      <ul
        class="font-medium items-center flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-8 md:mt-0 md:border-0 md:bg-stone-100 dark:bg-slate-800 md:dark:bg-slate-800 dark:border-gray-700"
      >
        {
          data.pages.map((page) => {
            if (page.subpages && page.subpages.length > 0) {
              const dropdownId = `dropdownNavbar-${page.title.toLowerCase()}`;
              return (
                <li class="mx-2 relative group">
                  <button
                    id={`${dropdownId}Link`}
                    data-dropdown-toggle={dropdownId}
                    class="flex items-center justify-between w-full py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:p-0 dark:text-white md:dark:hover:text-brand-amber dark:focus:text-white dark:border-gray-700 dark:hover:bg-gray-700 md:dark:hover:bg-transparent"
                  >
                    {page.title}{" "}
                    <svg
                      class="w-2.5 h-2.5 ms-2.5"
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 10 6"
                    >
                      <path
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="m1 1 4 4 4-4"
                      />
                    </svg>
                  </button>
                  {/* Dropdown menu */}
                  <div
                    id={dropdownId}
                    class="z-10 hidden font-normal bg-white divide-y divide-gray-100 rounded-lg shadow w-44 dark:bg-gray-700 dark:divide-gray-600 md:absolute max-md:relative! max-md:w-full! max-md:shadow-none! max-md:bg-gray-50! dark:max-md:bg-slate-800! max-md:transform-none! max-md:top-auto! max-md:left-auto! max-md:mt-2!"
                  >
                    <ul
                      class="py-2 text-sm text-gray-700 dark:text-gray-400"
                      aria-labelledby={`${dropdownId}Link`}
                    >
                      <li>
                        <a
                          href={page.href}
                          class="block px-4 max-md:pl-8 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
                        >
                          Overview
                        </a>
                      </li>
                      {page.subpages.map((sub: any) => (
                        <li>
                          <a
                            href={sub.href}
                            class="block px-4 max-md:pl-8 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 dark:hover:text-white"
                          >
                            {sub.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </li>
              );
            }

            return (
              <li class="mx-2">
                <a
                  href={page.href}
                  class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0  md:p-0 dark:text-white dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent"
                  aria-label={`Go to ${page.title} page`}
                >
                  {page.title}
                </a>
              </li>
            );
          })
        }
        <li class="mx-2 mt-4 md:mt-0">
          <a
            href="/RequestAudit"
            class="text-slate-900 bg-brand-amber hover:bg-amber-600 focus:ring-4 focus:outline-none focus:ring-amber-300 font-medium rounded-lg text-sm px-4 py-2 text-center dark:bg-amber-600 dark:hover:bg-amber-700 dark:focus:ring-amber-800 transition-colors"
          >
            Get a High-Stakes Audit
          </a>
        </li>
        <li class="mx-2 mt-4 md:mt-0 flex items-center">
          <DarkModeToggle />
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
  .hamburg {
    fill: black;
  }
  body.dark .hamburg {
    fill: white;
  }
</style>

<script>
  import { initDropdowns } from "flowbite";

  function initNav() {
    const $targetEl = document.getElementById("targetEl") as HTMLElement | null;
    const $triggerEl = document.getElementById("triggerEl") as HTMLElement | null;

    if (!$targetEl || !$triggerEl) return;

    // --- Hamburger toggle ---
    // Remove existing listener by cloning the button
    const newTrigger = $triggerEl.cloneNode(true) as HTMLElement;
    $triggerEl.parentNode?.replaceChild(newTrigger, $triggerEl);

    newTrigger.addEventListener("click", () => {
      const isHidden = $targetEl.classList.contains("hidden");
      if (isHidden) {
        $targetEl.classList.remove("hidden");
        $targetEl.classList.add("block");
        newTrigger.setAttribute("aria-expanded", "true");
      } else {
        $targetEl.classList.add("hidden");
        $targetEl.classList.remove("block");
        newTrigger.setAttribute("aria-expanded", "false");
      }
    });

    // --- Force-close menu on any link click BEFORE navigation starts ---
    // This prevents the InvalidStateError caused by Flowbite's animation
    // conflicting with Astro's View Transition DOM capture.
    $targetEl.querySelectorAll("a[href]").forEach((link) => {
      link.addEventListener("click", () => {
        // Instant sync hide — no animation, no Flowbite state conflict
        $targetEl.classList.add("hidden");
        $targetEl.classList.remove("block");
        newTrigger.setAttribute("aria-expanded", "false");
      });
    });

    // Close any open dropdowns
    document.querySelectorAll('div[id^="dropdownNavbar-"]').forEach((d) => {
      d.classList.remove("block");
      d.classList.add("hidden");
    });

    // Ensure menu starts closed on each page load
    $targetEl.classList.add("hidden");
    $targetEl.classList.remove("block");

    initDropdowns();
  }

  document.addEventListener("astro:page-load", initNav);
</script>
