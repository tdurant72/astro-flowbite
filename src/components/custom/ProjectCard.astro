---
import { Image, Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { CollectionEntry } from "astro:content";
import CardTop from "../../assets/images/card-mask2.svg";
import CustomTags from "./CustomTags.astro";

const { project } = Astro.props;
const { title, developer, tags, description } = project.data;
const projectImageSrc =
  typeof project.data.projectimage === "string"
    ? project.data.projectimage
    : project.data.projectimage?.src;
interface Props {
  project: CollectionEntry<"projects">;
}
// console.log("Entry:", project);
---

<a href=`/projects/${project.id.replace('.mdx','')}`>
  <div class="rounded-md shadow-md h-[300px] w-[350px] overflow-hidden">
    <div class="h-[300px] w-[350px] relative bg-white">
      <Image
        id="cardTop"
        src={CardTop}
        height={300}
        width={350}
        alt="top"
        loading="lazy"
        class="z-10 absolute"
      />
      {
        projectImageSrc && (
          <Image
            src={projectImageSrc}
            width={400}
            height={400}
            widths={[400, 800, 1200]}
            sizes="(max-width: 767px) 90vw, 400px"
            alt={project.data.alt}
            loading="lazy"
            class="z-0 object-cover absolute top-4 h-full w-full"
            transition:name={project.id}
          />
        )
      }
      <!-- <Picture
        src={project.data.projectimage.src}
        widths={[400, 800, 1200]}
        sizes="(max-width: 767px) 90vw, 400px"
        alt={project.data.projectimage.alt}
        loading="lazy"
        class="z-0 object-cover absolute top-4 h-full w-full"
        transition:name={project.id}
      /> -->
      <div
        class="absolute bottom-0 left-0 right-0 p-4 z-20 bg-linear-to-t from-gray-900 to-transparent"
      >
        <h3 class="text-white font-bold text-xl mb-1">
          {title}
        </h3>
        <!-- <p class="text-teal-400 font-semibold text-sm">
          Astro Architecture • Higher Conversions
        </p> -->
      </div>
    </div>
  </div>
</a>
