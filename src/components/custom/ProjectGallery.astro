---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import { Button } from "../ui/button";

const allProjects = await getCollection("projects");
const filteredProjects = allProjects.filter(
  (project) => project.data.type === "highlighted",
);
---

<section class="max-w-7xl mx-auto px-4 md:px-6 py-12 lg:py-24">
  <div
    id="gallery"
    class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    {filteredProjects.map((project) => <ProjectCard project={project} />)}
    <!-- put back gallery -->
  </div>
  <div class="mt-8 flex justify-center">
    <Button
      asChild
      className="bg-brand-teal text-white hover:bg-teal-600 px-8 py-2 text-lg rounded-lg"
    >
      <a href="/projects">More Projects</a>
    </Button>
  </div>
</section>
