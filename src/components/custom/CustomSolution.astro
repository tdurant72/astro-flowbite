---
import "aos/dist/aos.css";
import { Image } from "astro:assets";
import VideoCall from "../../assets/images/video-call.webp";
import { Button } from "../ui/button";
---

<!-- https://gist.github.com/goodreds/3d044027175954984fb96c7407a955ab --><!-- Container -->
<section class="max-w-7xl mx-auto px-4 md:px-6 py-12 lg:py-24">
  <div
    class="relative flex flex-col items-center mx-auto lg:flex-row-reverse lg:mt-0 md:m-0"
  >
    <!-- <div class="curve absolute h-[250px] top-0"></div> -->
    <!-- <div class="custom-shape-divider-top-1728589509">
      <svg
        data-name="Layer 1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"
          class="shape-fill"></path>
      </svg>
    </div> -->
    <!-- Image Column -->
    <div
      class="w-full h-64 lg:w-1/2 lg:h-[640px] overflow-hidden rounded-2xl shadow-xl"
    >
      <Image
        class="h-full w-full object-cover"
        src={VideoCall}
        alt="Video call"
        height={640}
      />
    </div>
    <!-- Close Image Column -->

    <!-- Text Column -->
    <div
      class="max-w-lg bg-white dark:bg-slate-900 md:max-w-2xl md:z-10 shadow-xl md:absolute md:top-0 md:mt-48 lg:w-3/5 lg:left-0 lg:mt-20 lg:ml-20 xl:mt-24 xl:ml-12 rounded-3xl border border-slate-100 dark:border-slate-800"
      data-aos="fade-up"
      data-aos-delay="500"
      data-aos-easing="ease-in-sine"
    >
      <!-- Text Wrapper -->
      <div class="flex flex-col p-10 md:p-12 lg:p-16">
        <h2
          class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight"
        >
          Experience our <span class="text-brand-teal">secure</span>, <span
            class="text-brand-teal">scalable</span
          >, and conversion-engineered process.
        </h2>
        <ul role="list" class="mb-8 space-y-5 text-left mt-8">
          <li class="flex items-center space-x-4">
            <div class="bg-teal-50 dark:bg-teal-900/30 p-1 rounded-full">
              <svg
                class="shrink-0 w-5 h-5 text-teal-600 dark:text-teal-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-lg text-slate-600 dark:text-slate-400"
              >Video call real-time collaboration</span
            >
          </li>
          <li class="flex items-center space-x-4">
            <div class="bg-teal-50 dark:bg-teal-900/30 p-1 rounded-full">
              <svg
                class="shrink-0 w-5 h-5 text-teal-600 dark:text-teal-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-lg text-slate-600 dark:text-slate-400"
              >Guaranteed mobile site speeds in the 90%</span
            >
          </li>
          <li class="flex items-center space-x-4">
            <div class="bg-teal-50 dark:bg-teal-900/30 p-1 rounded-full">
              <svg
                class="shrink-0 w-5 h-5 text-teal-600 dark:text-teal-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-lg text-slate-600 dark:text-slate-400"
              >Work directly with our expert designers</span
            >
          </li>
        </ul>
        <!-- Button Container -->
        <div class="mt-4">
          <Button
            asChild
            className="h-14 px-8 bg-brand-teal text-white text-lg font-bold hover:bg-teal-600 transition-all duration-300 rounded-full shadow-lg hover:shadow-brand-teal/25 inline-flex items-center justify-center min-w-[260px]"
          >
            <a href="#contact-us">Request Architecture Review</a>
          </Button>
        </div>
      </div>
      <!-- Close Text Wrapper -->
    </div>
    <!-- Close Text Column -->
  </div>
</section>

<style>
  /* .curve::before {
    content: "";
    display: block;
    position: absolute;
    border-radius: 100% 50%;
    width: 55%;
    height: 100%;
    transform: translate(85%, 60%);
  }
  .curve::after {
    content: "";
    display: block;
    position: absolute;
    border-radius: 100% 50%;
    width: 55%;
    height: 100%;
    background-color: #3de4c1;
    transform: translate(-4%, 40%);
  } */
  .custom-shape-divider-top-1728589509 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .custom-shape-divider-top-1728589509 .shape-fill {
    fill: #3de4c1;
  }
</style>
