---
import { Button } from "../ui/button";

const features = [
  {
    id: 1,
    name: "Institutional Authority Architecture",

    description:
      "Multi-system integration for established brands and regional scaling.",
    icon: "../src/assets/icons/monitor.webp",

    cta: "Our Approach To Authority",
    ctaLink: "/services#design",
  },
  {
    id: 2,
    name: "High-Velocity Lead Generation",

    description:
      "Attract highly-qualified institutional search traffic by optimizing your technical search infrastructure.",
    icon: "../src/assets/icons/rocket.webp",
    cta: "How We Optimize Lead Flow",
    ctaLink: "/services#seo",
  },
  {
    id: 3,
    name: "Mission-Critical Conversion Systems",

    description:
      "Eliminate friction and maximize conversions with elite, frictionless UX mapping.",
    icon: "../src/assets/icons/banner.webp",
    cta: "Why Conversion Systems Matter",
    ctaLink: "/services#growth",
  },
];
---

<section class="bg-slate-50 dark:bg-slate-950 py-16 lg:py-24">
  <div class="px-4 md:px-6 mx-auto max-w-7xl">
    <div class="mx-auto max-w-4xl text-center mb-16 lg:mb-24">
      <h2
        class="mb-6 text-4xl md:text-5xl lg:text-6xl tracking-tight font-extrabold text-slate-900 dark:text-white leading-tight"
      >
        Enterprise Grade Web Design, <br class="hidden lg:block" /> SEO & Technical
        Strategy
      </h2>
      <p
        class="font-light text-slate-600 text-xl md:text-2xl dark:text-slate-400"
      >
        Sublime UX builds mission critical digital assets that transform how
        your organization interacts with the world.
      </p>
    </div>
    <div class="space-y-8 lg:grid lg:grid-cols-3 gap-8 xl:gap-12 lg:space-y-0">
      <div
        class="flex flex-col items-center p-10 mx-auto max-w-lg text-center text-slate-900 bg-white rounded-3xl border border-slate-100 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-white transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 group"
      >
        <div
          class="mb-8 p-4 bg-teal-50 dark:bg-teal-900/30 rounded-2xl group-hover:bg-teal-500 group-hover:text-white transition-colors duration-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-monitor"
            ><rect width="20" height="14" x="2" y="3" rx="2"></rect><line
              x1="8"
              x2="16"
              y1="21"
              y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg
          >
        </div>
        <h3 class="mb-4 text-2xl font-bold tracking-tight">
          Institutional Authority Architecture
        </h3>
        <p
          class="font-light text-slate-600 text-lg dark:text-slate-400 mb-10 flex-grow"
        >
          High-trust interface design for organizations that require absolute
          precision and technical stability.
        </p>

        <Button
          asChild
          className="h-12 px-8 bg-slate-900 dark:bg-teal-500 text-white font-bold rounded-full hover:bg-teal-600 transition-all duration-300"
        >
          <a href="/services#design">View Strategy</a>
        </Button>
      </div>
      <div
        class="flex flex-col items-center p-10 mx-auto max-w-lg text-center text-slate-900 bg-white rounded-3xl border border-slate-100 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-white transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 group"
      >
        <div
          class="mb-8 p-4 bg-teal-50 dark:bg-teal-900/30 rounded-2xl group-hover:bg-teal-500 group-hover:text-white transition-colors duration-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-rocket"
            ><path
              d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
            ></path><path
              d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
            ></path><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"></path><path
              d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"></path></svg
          >
        </div>
        <h3 class="mb-4 text-2xl font-bold tracking-tight">
          High-Velocity Lead Generation
        </h3>
        <p
          class="font-light text-slate-600 text-lg dark:text-slate-400 mb-10 flex-grow"
        >
          SEO infrastructure built on pure performance, ensuring your
          organization is visible when it matters most.
        </p>

        <Button
          asChild
          className="h-12 px-8 bg-slate-900 dark:bg-teal-500 text-white font-bold rounded-full hover:bg-teal-600 transition-all duration-300"
        >
          <a href="/services#seo">View Strategy</a>
        </Button>
      </div>
      <div
        class="flex flex-col items-center p-10 mx-auto max-w-lg text-center text-slate-900 bg-white rounded-3xl border border-slate-100 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-white transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 group"
      >
        <div
          class="mb-8 p-4 bg-teal-50 dark:bg-teal-900/30 rounded-2xl group-hover:bg-teal-500 group-hover:text-white transition-colors duration-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="60"
            height="60"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-mouse-pointer-click"
            ><path d="m9 9 5 12 1.774-5.226L21 14Z"></path><path
              d="m16.071 16.071 4.243 4.243"></path><path
              d="m7.188 2.239.777 2.897"></path><path d="m2.239 7.188 2.897.777"
            ></path><path d="m5.274 5.274 2.121 2.121"></path></svg
          >
        </div>
        <h3 class="mb-4 text-2xl font-bold tracking-tight">
          Mission-Critical Conversion Systems
        </h3>
        <p
          class="font-light text-slate-600 text-lg dark:text-slate-400 mb-10 flex-grow"
        >
          Mapping the institutional buyer's journey to eliminate friction and
          maximize high-value action.
        </p>

        <Button
          asChild
          className="h-12 px-8 bg-slate-900 dark:bg-teal-500 text-white font-bold rounded-full hover:bg-teal-600 transition-all duration-300"
        >
          <a href="/services#growth">View Strategy</a>
        </Button>
      </div>
    </div>
  </div>
</section>
