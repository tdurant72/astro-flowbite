---

---

<div class="w-full max-w-2xl" id="contact-form">
  <div class="mb-8">
    <h3
      class="text-2xl md:text-3xl font-extrabold text-slate-900 dark:text-white mb-4"
    >
      Let's Architect Your Growth.
    </h3>
    <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed">
      Stop paying a friction tax. Provide your details below, and an architect
      will reach out to analyze your digital infrastructure and conversion
      pipeline.
    </p>
  </div>

  <form
    data-netlify="true"
    name="contact"
    method="POST"
    action="/success"
    class="space-y-6"
  >
    <div class="grid md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label
          for="name"
          class="block text-sm font-bold uppercase tracking-widest text-slate-700 dark:text-slate-300"
        >
          Full Name
        </label>
        <input
          id="name"
          type="text"
          name="name"
          required
          placeholder="John Smith"
          class="w-full h-14 px-4 bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white rounded-2xl focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 transition-all duration-300 outline-none placeholder:text-slate-400 dark:placeholder:text-slate-600"
        />
      </div>

      <div class="space-y-2">
        <label
          for="email"
          class="block text-sm font-bold uppercase tracking-widest text-slate-700 dark:text-slate-300"
        >
          Email Address
        </label>
        <input
          id="email"
          type="email"
          name="email"
          required
          placeholder="jsmith@organization.com"
          class="w-full h-14 px-4 bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white rounded-2xl focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 transition-all duration-300 outline-none placeholder:text-slate-400 dark:placeholder:text-slate-600"
        />
      </div>
    </div>

    <div class="space-y-2">
      <label
        for="message"
        class="block text-sm font-bold uppercase tracking-widest text-slate-700 dark:text-slate-300"
      >
        Project Focus
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="4"
        class="w-full p-4 bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white rounded-2xl focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 transition-all duration-300 outline-none placeholder:text-slate-400 dark:placeholder:text-slate-600 resize-none"
        >Reach out and let's start our conversion</textarea
      >
    </div>

    <button
      type="submit"
      class="inline-flex items-center justify-center w-full md:w-auto px-10 h-14 bg-slate-900 dark:bg-white text-white dark:text-slate-900 text-lg font-bold rounded-full hover:bg-slate-800 dark:hover:bg-slate-100 transition-all duration-300 shadow-lg hover:shadow-xl active:scale-95"
    >
      Initiate Audit Request
    </button>
  </form>
</div>
