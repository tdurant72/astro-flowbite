---
import { Image } from "astro:assets";
import data from "../data/site.json";
import Logo from "../assets/logo.png";
import {
  Mail,
  Phone,
  Twitter,
  Youtube,
  Linkedin,
  ArrowUpRight,
} from "@lucide/astro";
---

<footer
  class="bg-white dark:bg-slate-900 border-t border-slate-100 dark:border-slate-800 pt-20 pb-10"
>
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16"
    >
      <!-- Column 1: Brand -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3">
          <Image
            src={Logo}
            width={40}
            height={40}
            alt="Sublime UX Logo"
            class="grayscale hover:grayscale-0 transition-all duration-300"
          />
          <span
            class="text-xl font-bold tracking-tight text-slate-900 dark:text-white uppercase"
            >{data.siteName}</span
          >
        </a>
        <p class="text-slate-500 dark:text-slate-400 leading-relaxed max-w-xs">
          Engineering high-performance digital infrastructure for institutional
          authority and rapid regional growth.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://x.com/sublime_ux"
            target="_blank"
            class="p-2 rounded-full bg-slate-50 dark:bg-slate-800 text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-all"
          >
            <Twitter size={18} />
          </a>
          <a
            href="https://youtube.com/@sublimeux"
            target="_blank"
            class="p-2 rounded-full bg-slate-50 dark:bg-slate-800 text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-all"
          >
            <Youtube size={18} />
          </a>
          <a
            href="https://linkedin.com/in/tyus-durant-98697511"
            target="_blank"
            class="p-2 rounded-full bg-slate-50 dark:bg-slate-800 text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-all"
          >
            <Linkedin size={18} />
          </a>
        </div>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h4
          class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6"
        >
          Expertise
        </h4>
        <ul class="space-y-4">
          <li>
            <a
              href="/services"
              class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors inline-flex items-center group"
            >
              Institutional Audit <ArrowUpRight
                size={14}
                class="ml-1 opacity-0 group-hover:opacity-100 transition-all"
              />
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors inline-flex items-center group"
            >
              Revenue Architecture <ArrowUpRight
                size={14}
                class="ml-1 opacity-0 group-hover:opacity-100 transition-all"
              />
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors inline-flex items-center group"
            >
              Astro Migration <ArrowUpRight
                size={14}
                class="ml-1 opacity-0 group-hover:opacity-100 transition-all"
              />
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors inline-flex items-center group"
            >
              Growth Strategy <ArrowUpRight
                size={14}
                class="ml-1 opacity-0 group-hover:opacity-100 transition-all"
              />
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Company -->
      <div>
        <h4
          class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6"
        >
          Explore
        </h4>
        <ul class="space-y-4">
          {
            data.pages.map((page) => (
              <li>
                <a
                  href={page.href}
                  class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors underline-offset-4 hover:underline"
                >
                  {page.title}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/blog"
              class="text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors underline-offset-4 hover:underline"
            >
              Insights & Intelligence
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div class="space-y-6">
        <h4
          class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-6"
        >
          Connect
        </h4>
        <div class="space-y-4">
          <a
            href="mailto:todurant@sublimeux.com"
            class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
          >
            <Mail size={18} class="text-brand-teal" />
            <span>todurant@sublimeux.com</span>
          </a>
          <a
            href="tel:3365177923"
            class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
          >
            <Phone size={18} class="text-brand-teal" />
            <span>(336) 517-7923</span>
          </a>
        </div>
        <div class="pt-4">
          <p
            class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2"
          >
            Regional Hub
          </p>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Greensboro, NC 27405
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="pt-8 border-t border-slate-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left"
    >
      <p class="text-sm text-slate-500 dark:text-slate-400">
        &copy; {new Date().getFullYear()}
        {data.siteName}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/privacy"
          class="text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors"
          >Privacy Policy</a
        >
        <a
          href="/terms"
          class="text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors"
          >Terms of Service</a
        >
      </div>
    </div>
  </div>
</footer>
