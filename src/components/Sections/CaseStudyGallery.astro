---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
// import GallerySection from "../React/GallerySection.tsx";
import FeaturedCaseStudies from "@/components/React/FeaturedCaseStudies.tsx";

import Button from "../Button.astro";
const projects = await getCollection("projects");

const caseStudies = projects.filter(
    (project) => project.data.type === "highlighted",
);

const formattedProjects = await Promise.all(
    caseStudies.map(async (project, index) => {
        const projectImageSrc =
            typeof project.data.projectimage === "string"
                ? project.data.projectimage
                : project.data.projectimage?.src;
        const projectAlt = project.data.alt || project.data.title;

        // Pre-optimize image for the gallery card
        const optimizedImage = projectImageSrc
            ? await getImage({
                  src: projectImageSrc,
                  width: 600,
                  format: "avif",
                  quality: 80,
              })
            : null;

        return {
            id: String(index + 1).padStart(2, "0"),
            slug: project.id,
            title: project.data.title,
            category:
                project.data.description || project.data.type || "Case Study",
            image: optimizedImage?.src || projectImageSrc || "",
            video: project.data.projectvideo?.src || "",
            preview: optimizedImage?.src || projectImageSrc || "",
            alt: projectAlt,
        };
    }),
);

console.log(formattedProjects[0]);
---

<div
    class="container mx-auto h-full min-h-screen w-full pb-16"
    data-aos="fade-up"
    data-aos-delay="100"
>
    <!-- <GallerySection client:load caseStudies={caseStudies} /> -->
    <FeaturedCaseStudies projects={formattedProjects} client:load />
    <div data-aos="fade-up" class="flex justify-center">
        <Button text="View More Projects" href="/projects" />
    </div>
</div>
