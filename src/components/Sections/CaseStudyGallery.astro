---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import { ArrowBigLeft, ArrowBigRight } from "@lucide/astro";
import { Image } from "astro:assets";
// import GallerySection from "../React/GallerySection.tsx";
// import FeaturedCaseStudies from "@/components/React/FeaturedCaseStudies.tsx";
import Button from "@/components/Button.astro";
const projects = await getCollection("projects");

const caseStudies = projects.filter(
  (project) => project.data.type === "highlighted",
);

const formattedProjects = await Promise.all(
  caseStudies.map(async (project, index) => {
    const projectImageSrc =
      typeof project.data.projectimage === "string"
        ? project.data.projectimage
        : project.data.projectimage?.src;
    const projectAlt = project.data.alt || project.data.title;

    // Pre-optimize image for the gallery card
    const optimizedImage = projectImageSrc
      ? await getImage({
          src: projectImageSrc,
          widths: [320, 640, 880],
          format: "avif",
          quality: 80,
        })
      : null;

    return {
      id: String(index + 1).padStart(2, "0"),
      slug: project.id,
      title: project.data.title,
      description:
        project.data.description || project.data.type || "Case Study",
      category: project.data.description || project.data.type || "Case Study",
      image: optimizedImage,
      video: project.data.projectvideo?.src || "",
      preview: optimizedImage?.src || projectImageSrc || "",
      alt: projectAlt,
    };
  }),
);

// console.log(formattedProjects[0]);
---

<div
  class="container mx-auto h-full lg:min-h-screen w-full pb-4 lg:pb-16"
  data-aos="fade-up"
  data-aos-delay="100"
>
  <!-- <GallerySection client:load caseStudies={caseStudies} /> -->
  <!-- <FeaturedCaseStudies projects={formattedProjects} client:visible /> -->
  <section id="services">
    <!-- Header -->
    <header class="container flex items-center justify-between px-3 lg:px-6">
      <h2 class="bs-h2">Featured Case Studies</h2>

      <!-- Buttons -->
      <nav class="bs-st-button-wrapper flex justify-center gap-4">
        <!-- Prev -->
        <button
          aria-label="Previous slide"
          class="js-fc-btn-prev group bs-btn rounded-full !p-0 flex items-center justify-center h-10 w-10 md:h-12 md:w-12 bg-slate-900 text-slate-50"
        >
          <ArrowBigLeft
            class="opacity-60 h-4 w-4 -translate-x-[2px] group-active:translate-y-[1px]"
            height="16"
            width="25"
          />
        </button>

        <!-- Next -->
        <button
          aria-label="Next slide"
          class="js-fc-btn-next bg-slate-900 rounded-full !p-0 flex items-center justify-center h-10 w-10 md:h-12 md:w-12 text-slate-50"
        >
          <ArrowBigRight
            class="opacity-60 h-4 w-4 -translate-x-[2px] group-active:translate-y-[1px]text-slate-50"
            height={16}
            width="25"
          />
        </button>
      </nav>
    </header>

    <!-- Slides -->
    <div class="js-fc-swiper swiper select-none bs-mt-md">
      <div class="swiper-wrapper">
        {
          formattedProjects.map((project) => (
            // Slides
            <div class="swiper-slide bg-bs-surface-0 border border-bs-surface-3 rounded-xl overflow-hidden !h-auto">
              <figure class="flex flex-col gap-6 isolate min-h-[50svh] md:min-h-[40rem] h-full">
                {/* BG image */}
                <Image
                  src={project.image.src}
                  srcset={project.image.srcSet.attribute}
                  alt={project.alt}
                  loading="lazy"
                  class="rounded-xl overflow-hidden w-full h-full object-cover object-left absolute inset-0"
                  height="642"
                  width="472"
                  decoding="async"
                />

                {/* Gradient mask */}
                <div class="hidden md:block absolute rounded-xl overflow-hidden w-full h-full object-cover object-left inset-0 bg-linear-to-r from-neutral-100/90 via-neutral-from-neutral-100/60" />

                {/* Content */}
                <figcaption class="z-10 p-6 sm:p-10 md:p-20 max-w-xl flex flex-col gap-6 h-full bg-neutral-50/30 backdrop-blur-md">
                  {/* Title */}
                  <h2 class="text-xl md:text-3xl" set:html={project.title} />

                  {/* Intro */}
                  <div
                    class="text-2xl text-pretty flex-1"
                    set:html={project.description}
                  />

                  {/* Cta */}
                  <a
                    class="bg-brand-teal inline-block self-start my-6 mx-4 p-4 rounded-md text-neutral-50 "
                    href={`/projects/${project.slug.replace(".mdx", "")}`}
                    rel="noopener noreferrer"
                    target="_blank"
                  >
                    View Case Study
                  </a>
                </figcaption>
              </figure>
            </div>
          ))
        }
      </div>
    </div>

  </section>
  <div data-aos="fade-up" class="flex justify-center my-6">
    <Button text="View More Projects" href="/projects" />
  </div>
</div>

<script>
  import Swiper from "swiper";
  import "swiper/css";

  let swiper: Swiper | null = null;

  const destroyFeaturedSwiper = () => {
    if (swiper) {
      swiper.destroy();
      swiper = null;
    }
  };

  const initFeaturedSwiper = () => {
    const swiperElement = document.querySelector<HTMLElement>(".js-fc-swiper");
    if (!swiperElement) return;

    const prevBtn = document.querySelector<HTMLButtonElement>(".js-fc-btn-prev");
    const nextBtn = document.querySelector<HTMLButtonElement>(".js-fc-btn-next");

    destroyFeaturedSwiper();
    swiper = new Swiper(swiperElement, {
      slidesPerView: 1.05,
      spaceBetween: 8,
      speed: 500,
      loop: true,
      centeredSlides: true,
      breakpoints: {
        640: {
          slidesPerView: 1.2,
          spaceBetween: 32,
        },
        1600: {
          slidesPerView: 1.4,
          spaceBetween: 64,
        },
        1900: {
          slidesPerView: 1.6,
          spaceBetween: 64,
        },
      },
    });

    prevBtn?.addEventListener("click", () => swiper?.slidePrev());
    nextBtn?.addEventListener("click", () => swiper?.slideNext());
  };

  initFeaturedSwiper();
  document.addEventListener("astro:page-load", initFeaturedSwiper);
  document.addEventListener("astro:before-swap", destroyFeaturedSwiper);
</script>

<style>
  /* Show buttons only when in view */

  @keyframes show-buttons {
    to {
      opacity: 1;
    }
  }

  @supports (animation-timeline: view()) {
    .bs-st-button-wrapper {
      opacity: 0;
      animation: show-buttons linear forwards;
      animation-timeline: view(20% block);
    }
  }
</style>
