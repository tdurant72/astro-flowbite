---
import { Globe, Database, Shield } from "@lucide/astro";
const pillars = [
    {
        title: "Digital Brand Strategy",
        description:
            "Aligning diverse stakeholders under one visual voice that commands institutional authority.",
        icon: Globe,
        image: "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=1200",
    },
    {
        title: "Experience Architecture",
        description:
            "Simplifying complex data ecosystems for site selectors, citizens, and executive boards.",
        icon: Database,
        image: "https://images.unsplash.com/photo-1487958449943-2429e8be8625?auto=format&fit=crop&q=80&w=1200",
    },
    {
        title: "Platform Ecosystems",
        description:
            "Building scalable, secure, and accessible digital homes for your organization's legacy.",
        icon: Shield,
        image: "https://images.unsplash.com/photo-1511467687858-23d96c32e4ae?auto=format&fit=crop&q=80&w=1200",
    },
];
---

<section class="py-32 md:py-48 px-6 bg-[#4be3bf]" id="pillars">
    <span
        class="text-[8vw] uppercase tracking-tight font-semibold mb-8 block gradient-text text-right"
        data-aos="fade-down"
        data-aos-delay="200">Our Pillars</span
    >
    <div class="max-w-screen-xl mx-auto p-4">
        <div class="text-center mb-24">
            <h2 class="text-2xl md:text-4xl font-serif font-light">
                High Authority <span class="italic text-teal-50"
                    >Solutions.</span
                >
            </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-12">
            {
                pillars.map((pillar, idx) => (
                    <div
                        class="pillar-card bg-brand-paper p-12 rounded-[2rem] border border-brand-ink/5 hover:shadow-2xl hover:shadow-brand-ink/5 transition-all duration-500"
                        data-image={pillar.image}
                        data-aos="fade-left"
                        data-aos-delay={idx * 200}
                        data-aos-offset="300"
                        data-aos-easing="ease-in-sine"
                    >
                        <div class="w-16 h-16 rounded-2xl bg-brand-ink/5 flex items-center justify-center mb-8">
                            <pillar.icon
                                class="text-brand-ink text-teal-50"
                                size={32}
                            />
                        </div>
                        <h3 class="text-3xl font-serif mb-6">{pillar.title}</h3>
                        <p class="text-lg font-light leading-relaxed text-neutral-900">
                            {pillar.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
<script>
    const changeBackgroundImage = () => {
        const container = document.getElementById("pillars");
        const cards = document.querySelectorAll(".pillar-card");

        if (!container) return;

        // Add smooth transition for the background
        container.style.transition = "background-image 0.5s ease-in-out";
        container.style.backgroundSize = "cover";
        container.style.backgroundPosition = "center";

        cards.forEach((card) => {
            card.addEventListener("mouseenter", () => {
                const imageUrl = card.getAttribute("data-image");
                if (imageUrl) {
                    container.style.backgroundImage = `linear-gradient(rgba(75, 227, 191, 0.9), rgba(75, 227, 191, 0.9)), url(${imageUrl})`;
                }
            });
            card.addEventListener("mouseleave", () => {
                container.style.backgroundImage = "none";
            });
        });
    };

    // Run on initial load and handle Astro view transitions
    changeBackgroundImage();
    document.addEventListener("astro:page-load", changeBackgroundImage);
</script>
