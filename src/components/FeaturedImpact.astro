---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { ArrowRight } from "@lucide/astro";
import FeaturedImage from "@/assets/images/projects/ncgtpedrMockup.webp";
const allProjects = await getCollection("projects");
const featuredProject = allProjects.filter(
    (project) => project.data.type === "featured",
);
const { id } = featuredProject[0];
---

<section id="case-studies" class="py-4 md:py-32 lg:py-48 px-6">
    <span
        class="text-[8vw] uppercase tracking-tight font-semibold mb-8 block gradient-text"
        data-aos="fade-down"
        data-aos-delay="200">Featured Impact</span
    >
    <div
        class="max-w-screen-7xl mx-auto"
        data-aos="fade-up"
        data-aos-delay="100"
    >
        <div
            class="flex flex-col md:flex-row justify-between items-end mb-2 md:mb-12 lg:mb-24 gap-2 md:gap-8"
        >
            <div class="max-w-2xl" data-aos="fade-right" data-aos-delay="100">
                <h2
                    class="text-2xl md:text-4xl font-serif font-light leading-[0.9] tracking-tight"
                >
                    The 9M Regional <span class="italic text-brand-teal"
                        >Engine.</span
                    >
                </h2>
            </div>
            <p
                class="text-lg md:text-3xl font-light opacity-80 max-w-sm"
                data-aos="fade-left"
                data-aos-delay="100"
            >
                How we designed a fragmented economic development initiative
                into a unified regional powerhouse.
            </p>
        </div>

        <div
            id="featured-casestudy-card"
            class="relative group cursor-pointer overflow-hidden rounded-md md:rounded-3xl h-64 md:h-full"
            data-aos="fade-up"
            data-aos-delay="200"
        >
            {
                featuredProject.map((f) => (
                    <>
                        <div class="aspect-auto md:aspect-video overflow-hidden">
                            <Image
                                src={FeaturedImage}
                                widths={[320, 640, 1200]}
                                sizes="(max-width: 767px) 95vw, (max-width: 1279px) 90vw, 1200px"
                                format="avif"
                                quality={80}
                                alt="Case Study"
                                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000"
                                loading="lazy"
                                transition:name={f.id}
                            />
                        </div>
                        <div class="absolute inset-0 bg-brand-ink/20 group-hover:bg-brand-ink/0 transition-colors duration-700" />
                        <div class="absolute bottom-0 md:bottom-12 left-2 md:left-12 right-2 md:right-12 flex flex-col md:flex-row justify-between items-end gap-2 md:gap-8">
                            <div class="bg-brand-paper/90 backdrop-blur-md p-2 md:p-8 rounded-md md:rounded-2xl max-w-full md:max-w-xl text-neutral-50 min-h-[60%] md:min-h-0 flex flex-col justify-end bg-slate-950/30 md:bg-transparent">
                                <h3 class="text-2xl md:text-4xl font-serif mb-4">
                                    Hook → Impact
                                </h3>
                                <p class="text-sm md:text-base leading-relaxed opacity-80 mb-4 md:mb-7">
                                    A $9M Regional Investment Engine visualized
                                    across 14 distinct logistics data points. We
                                    reduced click-depth by 40% to transform a
                                    government archive into a recruitment tool."
                                </p>
                                <a
                                    href={`/projects/${id.replace(".mdx", "")}`}
                                    class="h-12 md:h-14 px-6 md:px-10 py-3 md:py-6 inline-flex items-center justify-center text-sm md:text-lg font-bold text-white bg-brand-teal rounded-full hover:bg-teal-600 transition-all duration-300 shadow-lg hover:shadow-brand-teal/25 group self-start"
                                >
                                    View Case Study <ArrowRight size={12} />
                                </a>
                            </div>
                            <div class="hidden md:flex flex-col items-end gap-2 text-brand-paper">
                                <span class="text-[10px] uppercase tracking-[0.3em] font-bold">
                                    01 / 04
                                </span>
                                <div class="h-px w-32 bg-brand-paper/40" />
                            </div>
                        </div>
                    </>
                ))
            }
        </div>
    </div>
</section>
