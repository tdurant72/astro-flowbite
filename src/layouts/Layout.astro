---
interface Props {
  title: string;
  description?: string;
  image?: string;
  frontmatter?: object;
}
import "../styles/global.css";
const { title, description } = Astro.props;
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PulsingCircle from "@/components/React/PulsingCircle";
import data from "../data/site.json";
import Seo from "@/components/custom/Seo.astro";
import "animate.css";
---

<!doctype html>
<html lang="en">
  <head transition:animate={fade({ duration: "0.4s" })}>
    <ClientRouter />

    <meta charset="UTF-8" />
    <meta name="description" content={data.siteDescription} />
    <meta
      name="keywords"
      content="Sublime UX, User Experience, web dsesign, web development, Greensboro, design, user interface, Triad, North Carolina, design expert, fast website, modern web site"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={data.siteName}
      href={`${Astro.site}rss.xml`}
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="9IyPrr2wq-W0ydHdMEZu2mV4qdB-kWtqkzsV2tMlpuE"
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      //check for dark mode in local storage using the theme var
      if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <script
      type="application/ld+json"
      class="json-ld"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Sublime UX",
        image: "https://www.sublimeux.com/images/socialImage.webp",
        telephone: "(336) 517-7923",
        email: "todurant@sublimeux.com",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Greensboro",
          addressRegion: "NC",
          postalCode: "27405",
        },
        url: "https://www.sublimeux.com/",
        sameAs: [
          "https://twitter.com/sublime_ux",
          "https://www.youtube.com/@sublimeux",
          "https://www.linkedin.com/in/tyus-durant-98697511",
        ],
        description: data.siteDescription,
        priceRange: "$$",
      })}
    />
    <Seo title={title} description={description} image={data.image} />
  </head>
  <body>
    <div
      class="relative bg-white dark:bg-slate-900 min-h-screen overflow-x-hidden"
    >
      <Nav />
      <slot />
      <PulsingCircle client:only="react" />
      <Footer />
    </div>
    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      const initAOS = () => {
        AOS.init({
          duration: 800,
          once: true,
          easing: "ease-out-cubic",
        });
      };

      initAOS();
      document.addEventListener("astro:after-swap", initAOS);
    </script>
    <!-- <script type="text/javascript" is:inline>
      (function (d, t) {
        var v = d.createElement(t),
          s = d.getElementsByTagName(t)[0];
        v.onload = function () {
          window.voiceflow.chat.load({
            verify: { projectID: "67609c9373a2bb187bcbd163" },
            url: "https://general-runtime.voiceflow.com",
            versionID: "production",
          });
        };
        v.src = "https://cdn.voiceflow.com/widget/bundle.mjs";
        v.type = "text/javascript";
        s.parentNode.insertBefore(v, s);
      })(document, "script");
    </script> -->
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      .section {
        padding: 60px 0;
      }
      #footer {
        position: fixed;
      }

      @media (max-width: 767px) {
        main {
          min-height: calc(100vh - 69px);
        }
        footer > ul > li {
          display: none;
        }
        footer {
          position: relative;
        }
      }
    </style>
  </body>
</html>
