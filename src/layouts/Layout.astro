---
import "@fontsource-variable/inter";
interface Props {
  title: string;
  description?: string;
  image?: string;
  frontmatter?: Record<string, any>;
}
import "../styles/global.css";
const { title, description, image, frontmatter } = Astro.props;
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
// import PulsingCircle from "@/components/React/PulsingCircle";
import MagneticContact from "@/components/MagneticContact.astro";
import data from "../data/site.json";
import Seo from "@/components/custom/Seo.astro";
---

<!doctype html>
<html lang="en">
  <head transition:animate={fade({ duration: "0.4s" })}>
    <ClientRouter />

    <meta charset="UTF-8" />
    <meta name="description" content={data.siteDescription} />
    <meta
      name="keywords"
      content="Sublime UX, User Experience, web design, web development, Greensboro, design, user interface, Triad, North Carolina, design expert, fast website, modern web site"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={data.siteName}
      href={`${Astro.site}rss.xml`}
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="9IyPrr2wq-W0ydHdMEZu2mV4qdB-kWtqkzsV2tMlpuE"
    />
    <title>{title}</title>
    <script is:inline>
      // Check for dark mode in local storage
      if (
        localStorage.getItem("theme") === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <Seo
      title={title}
      description={description}
      image={image ? { src: image, alt: title } : data.image}
      frontmatter={frontmatter}
    />
  </head>
  <body>
    <div class="relative bg-white dark:bg-slate-900 min-h-screen">
      <Nav />
      <slot />
      <!-- <PulsingCircle client:only="react" /> -->
      <MagneticContact />
      <Footer />
    </div>
    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      const initAOS = () => {
        AOS.init({
          duration: 800,
          once: true,
          easing: "ease-out-cubic",
        });
      };

      initAOS();
      document.addEventListener("astro:after-swap", initAOS);
    </script>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      .section {
        padding: 60px 0;
      }
      #footer {
        position: fixed;
      }

      @media (max-width: 767px) {
        main {
          min-height: calc(100vh - 69px);
        }
        footer > ul > li {
          display: none;
        }
        footer {
          position: relative;
        }
      }
    </style>
  </body>
</html>
