---
import { Image } from "astro:assets";

import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Prose from "../../components/Prose.astro";
import { getCollection, type CollectionEntry, render } from "astro:content";
import CustomTags from "../../components/custom/CustomTags.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}
const { project } = Astro.props;
const { Content } = await render(project);
---

<ProjectLayout {...project.data}>
  <a
    href="/#gallery"
    class="inline-block bg-gray-100 p-2 mb-6 hover:bg-indigo-500 hover:text-white"
    >Back To Home</a
  >
  <article>
    <div
      class="w-full max-h-[500px] overflow-hidden rounded-3xl mb-12 shadow-2xl relative"
    >
      <Image
        src={project.data.projectimage.src}
        alt={project.data.projectimage.alt}
        width={1200}
        height={600}
        class="w-full h-full object-cover"
        transition:name={project.id}
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent"
      >
      </div>
    </div>
    <div class="projectGrid">
      <h1 class="text-4xl font-bold mb-2">{project.data.title}</h1>

      <div class="mb-10">
        <CustomTags tags={project.data.tags} />
      </div>

      <Prose>
        <Content />
      </Prose>
    </div>
  </article>
</ProjectLayout>

<style>
  .projectGrid {
    display: grid;
    justify-items: center;
  }
</style>
