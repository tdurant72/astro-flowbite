---
import Layout from "../layouts/Layout.astro";
import Button from "@/components/Button.astro";
import ServicesAnimation from "../components/React/ServicesAnimation";
import PathToAnimation from "../components/React/PathToAnimation";
import {
  ArrowRight,
  CheckCheckIcon,
  Layers,
  Zap,
  Shield,
  Activity,
} from "@lucide/astro";

const title = "Services";
const subtitle =
  "Digital infrastructure services for non-profits and public-private partnerships";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Institutional Authority Architecture Services | Sublime UX",
  description:
    "Digital infrastructure services for non-profits and public-private partnerships. We engineer digital infrastructure to align stakeholders, index missions for AI, and accelerate regional impact.",
  mainEntity: {
    "@type": "OfferCatalog",
    name: "The Architecture of Progress",
    description:
      "Three tiers of engagement: Strategic Diagnostics, Digital Infrastructure, and Growth Ecosystems.",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Strategic Diagnostics",
          description:
            "The High-Stakes UX Audit. Focuses on discovery and de-risking by identifying the Friction Tax and achieving Narrative Consensus.",
        },
        position: 1,
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Digital Infrastructure",
          description:
            "V2V Experience Architecture & Institutional AI Indexing. Replacing legacy Information Bloat with a high-performance Astro-powered ecosystem.",
        },
        position: 2,
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Growth Ecosystems",
          description:
            "Impact Intelligence & Content Blueprinting. Ensuring your internal team has the Digital DNA to keep the platform authoritative as your mission expands.",
        },
        position: 3,
      },
    ],
  },
};
---

<Layout
  title="Services"
  description={jsonLd.description}
  frontmatter={{ schema: jsonLd }}
>
  <div class="pt-20 bg-white">
    {/* 1. The Hero: The High-Level Philosophy */}
    <section class="relative min-h-[80vh] flex items-center overflow-hidden">
      <div
        class="absolute inset-0 bg-grid-pattern opacity-50 pointer-events-none"
      >
      </div>

      <div
        class="max-w-7xl mx-auto px-6 w-full grid md:grid-cols-2 gap-16 items-center z-10"
      >
        <div class="space-y-8">
          <div data-aos="fade-right" data-aos-delay="100">
            <h1
              class="font-serif text-5xl md:text-7xl leading-[1.1] tracking-tight text-slate-800 text-balance mb-6"
            >
              Systems for Institutional Authority.
            </h1>
            <p
              class="font-sans text-xl text-slate-600 font-light leading-relaxed max-w-lg"
            >
              We don't offer "web design." We engineer the digital
              infrastructure required to align stakeholders, index missions for
              AI, and accelerate regional impact.
            </p>
          </div>
        </div>

        {/* 3D Wireframe Visual (SVG representation) */}
        <ServicesAnimation client:only />
      </div>
    </section>

    {/* 2. The Three Service Tiers */}
    <section class="py-32 bg-slate-800 text-white relative">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-20">
          <h2 class="font-serif text-4xl md:text-5xl mb-4">
            The Architecture of Progress
          </h2>
          <p class="font-mono text-xs uppercase tracking-widest text-slate-400">
            Engagement Models
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {/* Tier A */}
          <div
            class="border border-white/10 p-10 bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="mb-8">
              <span
                class="font-mono text-xs text-brand-teal uppercase tracking-widest"
                >The Entry</span
              >
              <h3 class="font-serif text-3xl mt-2 mb-4">
                Strategic Diagnostics
              </h3>
              <p class="font-sans text-slate-300 font-light">
                Focus: Discovery and De-risking.
              </p>
            </div>

            <div class="space-y-6 mb-12">
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >Key Service</span
                >
                <p class="font-sans">The High-Stakes UX Audit</p>
              </div>
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >The Goal</span
                >
                <p class="font-sans text-sm text-slate-200 leading-relaxed">
                  Identifying the "Friction Tax" and achieving Narrative
                  Consensus across your leadership team.
                </p>
              </div>
            </div>

            <div class="py-6 border-t border-white/10 flex items-center gap-3">
              <Activity class="w-5 h-5 text-brand-teal" />
              <span class="font-mono text-xs tracking-widest"
                >100% Diagnostic Accuracy</span
              >
            </div>
            <div class="pt-6 border-t border-white/10 flex items-center gap-3">
              <Button
                text="Learn More About How We Do Audits"
                href="/services/HighStakesAudit"
              />
            </div>
          </div>

          {/* Tier B */}
          <div
            class="border border-white/10 p-10 bg-white/5 hover:bg-white/10 transition-colors group relative overflow-hidden"
          >
            <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal"></div>
            <div class="mb-8">
              <span
                class="font-mono text-xs text-brand-teal uppercase tracking-widest"
                >The Core</span
              >
              <h3 class="font-serif text-3xl mt-2 mb-4">
                Digital Infrastructure
              </h3>
              <p class="font-sans text-slate-300 font-light">
                Focus: Building and Indexing.
              </p>
            </div>

            <div class="space-y-6 mb-12">
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >Key Services</span
                >
                <p class="font-sans">
                  V2V Experience Architecture & Institutional AI Indexing
                </p>
              </div>
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >The Goal</span
                >
                <p class="font-sans text-sm text-slate-200 leading-relaxed">
                  Replacing legacy "Information Bloat" with a high-performance
                  Astro-powered ecosystem invisible to friction but highly
                  visible to AI.
                </p>
              </div>
            </div>

            <div class="py-6 border-t border-white/10">
              <ul
                class="space-y-2 font-mono text-[10px] tracking-widest text-slate-300"
              >
                <li class="flex items-center gap-2">
                  <CheckCheckIcon class="w-3 h-3 text-brand-teal" /> JSON-LD Integrated
                </li>
                <li class="flex items-center gap-2">
                  <CheckCheckIcon class="w-3 h-3 text-brand-teal" /> 99+ Lighthouse
                  Speed
                </li>
                <li class="flex items-center gap-2">
                  <CheckCheckIcon class="w-3 h-3 text-brand-teal" /> WCAG 2.1 Accessible
                </li>
              </ul>
            </div>
            <div class="pt-6 border-t border-white/10 flex items-center gap-3">
              <Button
                text="Learn More The V2V Framework"
                href="/services/V2VFramework"
              />
            </div>
          </div>

          {/* Tier C */}
          <div
            class="border border-white/10 p-10 bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="mb-8">
              <span
                class="font-mono text-xs text-brand-teal uppercase tracking-widest"
                >The Scale</span
              >
              <h3 class="font-serif text-3xl mt-2 mb-4">Growth Ecosystems</h3>
              <p class="font-sans text-slate-300 font-light">
                Focus: Maintenance and Evolution.
              </p>
            </div>

            <div class="space-y-6 mb-12">
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >Key Services</span
                >
                <p class="font-sans">
                  Impact Intelligence & Content Blueprinting
                </p>
              </div>
              <div>
                <span
                  class="block font-mono text-[10px] text-slate-400 uppercase mb-1"
                  >The Goal</span
                >
                <p class="font-sans text-sm text-slate-200 leading-relaxed">
                  Ensuring your internal team has the "Digital DNA" to keep the
                  platform authoritative as your mission expands.
                </p>
              </div>
            </div>

            <div class="py-6 border-t border-white/10 flex items-center gap-3">
              <Layers class="w-5 h-5 text-brand-teal" />
              <span class="font-mono text-xs tracking-widest"
                >Long-term Sustainability</span
              >
            </div>
            <div class="pt-6 border-t border-white/10 flex items-center gap-3">
              <Button
                text="Learn More About Content Blueprinting"
                href="/services/ContentBlueprint"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* 3. The Methodology Section (V2V Machine) */}
    <section class="py-32 bg-white border-b border-slate-800/10">
      <div
        class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center"
      >
        <div>
          <h2 class="font-serif text-4xl md:text-5xl text-slate-800 mb-6">
            The V2V Machine
          </h2>
          <p
            class="font-sans text-lg text-slate-600 font-light leading-relaxed mb-8"
          >
            You aren't just buying features, you are buying a method. The
            Visibility-to-Velocity (V2V) framework ensures every digital
            touchpoint is engineered to move stakeholders from awareness to
            decisive action.
          </p>
          <div
            class="flex items-center gap-4 font-mono text-sm tracking-widest text-slate-800"
          >
            <span>VISIBILITY</span>
            <ArrowRight class="w-4 h-4 text-brand-teal" />
            <span>VELOCITY</span>
          </div>
        </div>
        <div
          class="relative h-64 bg-slate-800/5 flex items-center justify-center border border-slate-800/10"
        >
          <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
          <div class="flex items-center gap-8 z-10">
            <div
              class="w-24 h-24 rounded-full border border-slate-800/20 flex items-center justify-center"
            >
              <span class="font-serif text-2xl">V1</span>
            </div>
            <div
              class="w-32 h-1px bg-linear-gradient-to-r from-slate-800/20 to-brand-teal relative"
            >
              <PathToAnimation client:load />
            </div>
            <div
              class="w-24 h-24 rounded-full border border-brand-teal bg-brand-teal/5 flex items-center justify-center text-brand-teal"
            >
              <span class="font-serif text-2xl">V2</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* 4. The Stack Section */}
    <section class="py-32 bg-slate-800 text-white relative overflow-hidden">
      <div
        class="absolute inset-0 bg-grid-pattern opacity-10 pointer-events-none"
      >
      </div>
      <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
        <Shield class="w-12 h-12 text-brand-teal mx-auto mb-8" />
        <h2 class="font-serif text-4xl md:text-5xl mb-8">The Technical Soul</h2>
        <p
          class="font-sans text-xl text-slate-300 font-light leading-relaxed mb-12"
        >
          We build on the Astro framework—the same technology used by global
          leaders to ensure zero-latency performance and ironclad security. In
          the public sector, speed is trust.
        </p>
        <div
          class="inline-flex items-center gap-8 border border-white/10 px-8 py-4 bg-white/5"
        >
          <div class="flex items-center gap-2">
            <Zap class="w-4 h-4 text-brand-teal" />
            <span class="font-mono text-xs tracking-widest">Zero-Latency</span>
          </div>
          <div class="w-1px h-4 bg-white/20"></div>
          <div class="flex items-center gap-2">
            <Shield class="w-4 h-4 text-brand-teal" />
            <span class="font-mono text-xs tracking-widest"
              >Ironclad Security</span
            >
          </div>
        </div>
      </div>
    </section>

    {/* 5. Closing CTA */}
    <section class="py-40 bg-white text-center">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-serif text-5xl md:text-6xl text-slate-800 mb-6">
          Initiate Your Transformation
        </h2>
        <p class="font-sans text-xl text-slate-600 font-light mb-12">
          Not sure which track fits your mission? Start with a diagnostic.
        </p>
        <button
          class="group inline-flex items-center justify-center gap-4 px-8 py-5 bg-slate-800 text-white hover:bg-brand-teal transition-all duration-300"
        >
          <span class="font-mono text-sm uppercase tracking-widest font-medium"
            >Request a High-Stakes Audit</span
          >
          <ArrowRight
            class="w-4 h-4 transition-transform group-hover:translate-x-2"
          />
        </button>
      </div>
    </section>
  </div>
</Layout>

<style></style>
